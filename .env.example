# ==================================================
# PROJECT RenewAI — Environment Variables
# ==================================================
# Copy this file to .env and fill in your values.

# LLM Provider (set STUB=true to run without API keys)
LLM_PROVIDER=stub          # stub | openai | azure
OPENAI_API_KEY=sk-...
AZURE_OPENAI_ENDPOINT=https://....openai.azure.com/
AZURE_OPENAI_KEY=...
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Voice Engine (set VOICE_STUB=true to simulate calls)
VOICE_STUB=true
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=eastus

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
MAX_REGENERATE_LOOPS=3
CRITIQUE_COST_PER_MSG_INR=0.035

# IRDAI Config
IRDAI_FRAMEWORK_YEAR=2024
DPDPA_COMPLIANT=true
